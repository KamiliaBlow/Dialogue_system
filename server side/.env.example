PORT=3000
# Сгенерируйте сильный случайный ключ, например:
#   node -e "console.log(require('crypto').randomBytes(48).toString('base64'))"
SESSION_SECRET=REPLACEME_GENERATE_STRONG_SECRET
CORS_ORIGINS=https://your-domain.example,https://www.your-domain.example
# Сгенерируйте сильный случайный ключ для первичной настройки администратора:
#   node -e "console.log(require('crypto').randomBytes(24).toString('base64'))"
SETUP_KEY=REPLACEME_GENERATE_STRONG_KEY
DB_PATH=./database.db
SSL_KEY_PATH=ssl/privkey.pem
SSL_CERT_PATH=ssl/cert.pem
# Установите 1 ТОЛЬКО для локальной разработки без SSL. В проде должно быть 0.
ALLOW_HTTP=0
# Срок жизни сессионной куки в мс (по умолчанию 24 ч)
SESSION_MAX_AGE=86400000
